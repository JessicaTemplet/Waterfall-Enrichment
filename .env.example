# Copy this file to .env and fill in your values.
# python-dotenv or direnv can load it automatically.

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
# Default: local Redis, no auth, DB 0
REDIS_URL=redis://localhost:6379

# With password:
# REDIS_URL=redis://:yourpassword@localhost:6379/0

# Managed Redis (e.g. Upstash, Redis Cloud):
# REDIS_URL=rediss://default:yourtoken@host.upstash.io:6380

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Default: SQLite file in the working directory (fine for local dev)
DATABASE_URL=sqlite:///leadintel.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/leadintel
